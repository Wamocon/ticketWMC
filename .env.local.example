# ──────────────────────────────────────────────────────────────
# WMC Ticketsystem – Umgebungsvariablen
# Diese Datei ist nur eine VORLAGE. Zum lokalen Entwickeln:
#   cp .env.local.example .env.local
# und die echten Werte eintragen. .env.local wird NICHT committet.
# In Vercel werden dieselben Variablen im Projekt unter
#   Settings → Environment Variables  (verschlüsselt) hinterlegt.
# ──────────────────────────────────────────────────────────────

# Basis-URL eurer Jira-Cloud-Instanz (ohne abschließenden /)
JIRA_BASE_URL=https://EUER-DOMAIN.atlassian.net

# E-Mail des (Service-)Accounts, zu dem das API-Token gehört
JIRA_EMAIL=deine-Email@domain.com

# API-Token: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=

# Projekt-Key des WMC-Projekts (z. B. WMC)
JIRA_PROJECT_KEY=WIDEA

# Cloudflare-Turnstile Secret Key (serverseitige Verifikation)
# https://dash.cloudflare.com/ → Turnstile → Site hinzufügen
TURNSTILE_SECRET=

# Optional: kommagetrennte Liste erlaubter Herkunfts-Origins für den
# POST-Endpoint. Leer lassen = nur gleiche Domain (empfohlen).
# ALLOWED_ORIGINS=
